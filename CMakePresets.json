{
    "version": 3,
    "configurePresets": [
        {
            "name": "gcc",
            "displayName": "GCC",
            "description": "Use GCC toolchain",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/gcc",
            "hidden": false,
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "-g",
                "CMAKE_CXX_FLAGS": "-g",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/gcc",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_EXE_LINKER_FLAGS": "-g",
                "CMAKE_C_COMPILER": "d:/msys64/ucrt64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "d:/msys64/ucrt64/bin/g++.exe"
            }
        },
        {
            "name": "msvc",
            "displayName": "MSVC",
            "description": "Use MSVC toolchain",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/msvc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_FLAGS": "/Zi /Od",
                "CMAKE_CXX_FLAGS": "/Zi /Od",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/msvc",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_EXE_LINKER_FLAGS": "/DEBUG",
                "CMAKE_SHARED_LINKER_FLAGS": "/DEBUG",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "YES",
                "CMAKE_C_COMPILER": "cl.exe",
                "CMAKE_CXX_COMPILER": "cl.exe"
            }
        }
    ]
}
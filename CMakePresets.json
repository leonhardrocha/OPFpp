{
    "version": 3,
    "configurePresets": [
        {
            "name": "gcc",
            "displayName": "GCC",
            "description": "Uses Conan toolchain for GCC. Run 'conan install . --output-folder=build/gcc --build=missing' first.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/gcc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/gcc/conan_toolchain.cmake"
            }
        },
        {
            "name": "msvc",
            "displayName": "MSVC",
            "description": "Uses Conan toolchain for MSVC. Run 'conan install . --output-folder=build/msvc --build=missing -s build_type=Debug' first.",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/msvc/conan_toolchain.cmake"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "GCC",
            "description": "",
            "displayName": "",
            "configurePreset": "gcc"
        }
    ]
}